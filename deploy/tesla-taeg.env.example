# Credenciais do Verificador de TAEG — copia para /etc/tesla-taeg.env e edita.
# NÃO cometas este ficheiro com valores reais no git.

# Conta Gmail que envia o email de alerta.
GMAIL_USER=pflm.bet@gmail.com

# App Password de 16 letras do Gmail (sem espaços).
# Cria em: https://myaccount.google.com/apppasswords  (precisa de verificação em 2 passos)
GMAIL_APP_PASSWORD=coloca_aqui_a_app_password

# (Opcional) destinatário do alerta; por omissão = GMAIL_USER.
# NOTIFY_EMAIL=outro@email.com
